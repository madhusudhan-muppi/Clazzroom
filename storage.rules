rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Submissions folder
    match /submissions/{classroomId}/{assignmentId}/{studentId}/{fileName} {
      // Students can upload to their own folder. Mentors can read from it.
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == studentId;
    }

    // Assignment files folder (Mentors attaching files)
    match /assignments/{classroomId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Project files folder
    match /projects/{classroomId}/{projectId}/{fileName} {
      // Anyone authenticated can read project files (mentor + student)
      allow read: if request.auth != null;
      // Any authenticated user can write (student uploads their own)
      allow write: if request.auth != null;
    }

    // Default block all
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

